{
  "name": "opencode-go-for-copilot",
  "displayName": "OpenCode Go: Copilot Provider",
  "description": "Use Opencode Go models in VS Code Copilot Chat with silent startup model sync and dual OpenAI/Anthropic protocol support.",
  "version": "0.1.16",
  "type": "module",
  "publisher": "DenizhanDaklr",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/zelosleone/Opencode-Go-For-Copilot"
  },
  "icon": "media/icon.png",
  "engines": {
    "vscode": "^1.118.0"
  },
  "categories": [
    "AI",
    "Chat"
  ],
  "keywords": [
    "opencode",
    "opencode go",
    "copilot",
    "github copilot",
    "language model",
    "chat",
    "glm",
    "kimi",
    "qwen",
    "deepseek",
    "minimax"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "extensionKind": [
    "workspace",
    "ui"
  ],
  "contributes": {
    "languageModelChatProviders": [
      {
        "vendor": "opencode-go",
        "displayName": "Opencode Go"
      }
    ],
    "commands": [
      {
        "command": "opencodeGo.setApiKey",
        "title": "Opencode Go: Set API Key"
      },
      {
        "command": "opencodeGo.clearApiKey",
        "title": "Opencode Go: Clear API Key"
      },
      {
        "command": "opencodeGo.showRegisteredModels",
        "title": "Opencode Go: Show Registered Models"
      },
      {
        "command": "opencodeGo.showLogs",
        "title": "Opencode Go: Show Logs"
      }
    ],
    "configuration": {
      "title": "Opencode Go",
      "properties": {
        "opencodeGo.apiKey": {
          "type": "string",
          "default": "",
          "description": "Opencode Go API key fallback. Prefer the command palette to store it securely.",
          "scope": "application"
        },
        "opencodeGo.baseUrl": {
          "type": "string",
          "default": "https://opencode.ai/zen/go/v1",
          "description": "Opencode Go API base URL.",
          "scope": "application"
        },
        "opencodeGo.defaultMaxOutputTokens": {
          "type": "number",
          "default": 8192,
          "minimum": 256,
          "maximum": 65536,
          "description": "Default max output tokens for Opencode Go models that use the Anthropic-compatible endpoint, such as MiniMax.",
          "scope": "application"
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "build": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "20.19.30",
    "@types/vscode": "^1.118.0",
    "@typescript-eslint/eslint-plugin": "8.53.0",
    "@typescript-eslint/parser": "8.53.0",
    "@vscode/vsce": "^3.9.1",
    "eslint": "9.39.2",
    "globals": "17.0.0",
    "typescript": "5.9.3"
  }
}
